{
  "name": "ultimate-booking",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:security": "jest --testPathPattern=security",
    "functions:install": "npm --prefix functions install",
    "functions:build": "npm --prefix functions run build",
    "functions:setup": "npm run functions:install && npm run functions:build",
    "emulators": "firebase emulators:start --only auth,functions,firestore,storage --import=./emulator_data --export-on-exit",
    "emulators:export": "firebase emulators:export ./emulator-data",
    "dev:emulators": "npm run functions:setup && concurrently \"npm run emulators\" \"npm run dev\""
  },
  "dependencies": {
    "next": "14.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "firebase": "^10.12.2",
    "firebase-admin": "^12.2.0",
    "zustand": "^4.5.2",
    "@tanstack/react-query": "^5.45.1",
    "react-hook-form": "^7.52.0",
    "zod": "^3.23.8",
    "@hookform/resolvers": "^3.6.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "lucide-react": "^0.395.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0",
    "react-hot-toast": "^2.4.1",
    "react-datepicker": "^7.3.0",
    "@types/react-datepicker": "^6.2.0",
    "sharp": "^0.33.4",
    "resend": "^3.3.0",
    "react-leaflet": "^4.2.1",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "typescript": "^5.5.2",
    "@types/node": "^20.14.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/leaflet": "^1.9.12",
    "tailwindcss": "^3.4.4",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/user-event": "^14.5.2",
    "ts-jest": "^29.1.5",
    "@types/jest": "^29.5.12",
    "concurrently": "^8.2.2",
    "firebase-tools": "^13.12.0"
  }
}
